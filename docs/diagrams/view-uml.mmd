%%{init: {
  'theme': 'dark',
  'themeVariables': {
    'primaryColor': '#1e1e1e',
    'primaryTextColor': '#ffffff',
    'primaryBorderColor': '#ffffff',
    'lineColor': '#888888',
    'secondaryColor': '#2d2d2d',
    'tertiaryColor': '#1e1e1e'
  }
}}%%
classDiagram
    %% ── Core structs ──────────────────────────────────────────────
    class ViewContext~T~ {
        poise: Context
        action: Option~T~
        event: ViewEvent
        tx: Arc~dyn ViewSender~T~~
        coordinator: Arc~Coordinator~
        map(action, wrap) ViewContext~C~
        spawn(future)
    }

    class ActionRegistry~T~ {
        actions: HashMap~String, T~
        prefix: String
        counter: usize
        register(action: T) RegisteredAction
        register_with_id(id, action) Option~RegisteredAction~
        get(id: str) Option~&T~
        clear()
    }

    class ViewEngine~T, H~ {
        ctx: Context
        handler: H
        registry: Registry~T~
        timeout: Duration
        coordinator: Arc~Coordinator~
        should_acknowledge: bool
        render_view() Result
        run() Result
    }

    class ViewChannel~T~ {
        tx: UnboundedSender~EventMessage~T~~
        rx: UnboundedReceiver~EventMessage~T~~
        registry: Registry~T~
        config: ViewChannelConfig
        new(config, registry)
        sender() Arc~dyn ViewSender~T~~
        recv() Option~EventMessage~T~~
        start(ctx, msg_id, author_id, channel_id, timeout)
    }

    class ViewChannelConfig {
        components: bool
        modals: bool
        messages: bool
        reactions: bool
    }

    class MappedViewSender~C, P~ {
        parent_tx: Arc~dyn ViewSender~P~~
        wrap: fn(Option~C~) -> Option~P~
    }

    class RegisteredAction {
        id: String
        label: str
        as_button() CreateButton
        as_select(kind) CreateSelectMenu
        as_select_option() CreateSelectMenuOption
    }

    class Coordinator {
        ctx: Context
        nav_queue: Mutex~VecDeque~NavigationResult~~
        reply_handle: SharedReplyHandle
        context() Context
        navigate(next)
        run(initial_route)
    }

    class NavigationResult {
        <<enum>>
        Back
        Exit
        SettingsMain
        ...
    }

    class ViewCommand {
        <<enum>>
        Render
        RenderOnce
        Exit
        Continue
        AlreadyResponded
    }

    class ViewEvent {
        <<enum>>
        Component(ComponentInteraction)
        Modal(ModalInteraction)
        Message(Message)
        Reaction(Reaction)
        Async
        Timeout
    }

    %% ── Type aliases ──────────────────────────────────────────────
    class EventMessage~T~ {
        <<type alias>>
        Tuple of Option~T~ and ViewEvent
    }

    class Registry~T~ {
        <<type alias>>
        Arc wrapping RwLock of ActionRegistry~T~
    }

    %% ── Traits ────────────────────────────────────────────────────
    class Action {
        <<trait>>
        label() str
    }

    class ViewRender {
        <<trait>>
        type Action: Action
        render(registry) ResponseKind
        create_reply(registry) CreateReply
    }

    class ViewHandler {
        <<trait>>
        type Action: Action
        handle(ctx) Result~ViewCommand~
        on_timeout() Result~ViewCommand~
        channel_config() ViewChannelConfig
    }

    class Update {
        <<trait>>
        type Model
        type Msg
        type Cmd
        update(msg, model) Cmd
    }

    class ViewSender~T~ {
        <<trait>>
        send(message: EventMessage~T~)
    }

    class Controller {
        <<trait>>
        run(coordinator: Arc~Coordinator~) Result
    }

    %% ── Concrete Update examples ──────────────────────────────────
    class VoiceLeaderboardUpdate {
        <<impl Update>>
        Model = VoiceLeaderboardModel
        Msg = VoiceLeaderboardMsg
        Cmd = VoiceLeaderboardCmd
    }

    class VoiceStatsUpdate {
        <<impl Update>>
        Model = VoiceStatsModel
        Msg = VoiceStatsMsg
        Cmd = VoiceStatsCmd
    }

    class WelcomeSettingsUpdate {
        <<impl Update>>
        Model = WelcomeSettingsModel
        Msg = WelcomeSettingsMsg
        Cmd = WelcomeSettingsCmd
    }

    class FeedListUpdate {
        <<impl Update>>
        Model = FeedListModel
        Msg = FeedListMsg
        Cmd = FeedListCmd
    }

    class FeedSettingsUpdate {
        <<impl Update>>
        Model = FeedSettingsModel
        Msg = FeedSettingsMsg
        Cmd = FeedSettingsCmd
    }

    class SettingsMainUpdate {
        <<impl Update>>
        Model = SettingsMainModel
        Msg = SettingsMainMsg
        Cmd = SettingsMainCmd
    }

    %% ── Trait relationships ───────────────────────────────────────
    ViewEngine --> ViewHandler : owns
    ViewEngine --> ViewRender : owns
    ViewEngine --> ViewChannel : drives
    ViewEngine --> ActionRegistry : owns
    ViewChannel --> ActionRegistry : reads
    ViewHandler ..> ViewCommand : returns
    ViewHandler ..> ViewEvent : receives via ctx
    ViewHandler ..> ViewContext : receives
    ViewHandler ..> ViewChannelConfig : configures
    ViewHandler ..> Update : delegates to
    Update ..> ViewHandler : used by
    ActionRegistry ..> Action : maps
    ActionRegistry ..> RegisteredAction : produces
    MappedViewSender ..> ViewSender : implements
    ViewSender ..> EventMessage : sends
    Coordinator ..> Controller : drives
    Controller ..> NavigationResult : returns
    ViewContext ..> ViewSender : uses
    ViewContext ..> MappedViewSender : creates via map()
    VoiceLeaderboardUpdate ..> Update : implements
    VoiceStatsUpdate ..> Update : implements
    WelcomeSettingsUpdate ..> Update : implements
    FeedListUpdate ..> Update : implements
    FeedSettingsUpdate ..> Update : implements
    SettingsMainUpdate ..> Update : implements
