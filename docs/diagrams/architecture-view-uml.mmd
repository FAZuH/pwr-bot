    'tertiaryColor': '#1e1e1e'
  }
}}%%
classDiagram
    %% ── Core structs ──────────────────────────────────────────────
    class ViewContext~T~ {
        poise: Context
        event: ViewEvent~T~
        tx: Arc~dyn ViewSender~T~~
        coordinator: Arc~Coordinator~
        map(action, wrap) ViewContext~C~
        spawn(future)
    }

    class ActionRegistry~T~ {
        actions: HashMap~String, T~
        prefix: String
        counter: usize
        register(action: T) RegisteredAction
        get(id: str) Option~T~
        clear()
    }

    class ViewEngine~T, H~ {
        ctx: Context
        handler: H
        registry: ActionRegistry~T~
        timeout: Duration
        coordinator: Arc~Coordinator~
        should_acknowledge: bool
        render_view() Result
        run() Result
    }

    class RegisteredAction {
        id: String
        label: str
        as_button() CreateButton
        as_select(kind) CreateSelectMenu
        as_select_option() CreateSelectMenuOption
    }

    class Coordinator {
        ctx: Context
        nav_queue: Mutex~VecDeque~NavigationResult~~
        reply_handle: SharedReplyHandle
        context() Context
        navigate(next)
        run(initial_route)
    }

    class NavigationResult {
        <<enum>>
        Back
        Exit
        SettingsMain
        ...
    }

    class ViewCommand {
        <<enum>>
        Render
        RenderOnce
        Exit
        Continue
        AlreadyResponded
    }

    class ViewEvent {
        <<enum>>
        Component
        Modal
        Message
        Async
        Timeout
    }

    %% ── Traits ────────────────────────────────────────────────────
    class Action {
        <<trait>>
        label() str
    }

    class ViewRender~T: Action~ {
        <<trait>>
        render(registry) ResponseKind
        create_reply(registry) CreateReply
    }

    class ViewHandler~T: Action, S: Send + Sync~ {
        <<trait>>
        handle(ctx) Result~ViewCommand~
        on_timeout() Result~ViewCommand~
    }

    class Controller {
        <<trait>>
        run(coordinator: Arc~Coordinator~) Result
    }

    %% ── Trait relationships ───────────────────────────────────────
    ViewEngine --> ViewHandler : owns
    ViewEngine --> ViewRender : owns
    ViewEngine --> ActionRegistry : owns
    ViewHandler ..> ViewCommand : returns
    ViewHandler ..> ViewEvent : receives
    ViewHandler ..> ViewContext : receives
    ActionRegistry ..> Action : maps
    ActionRegistry ..> RegisteredAction : produces
    Coordinator ..> Controller : drives
    Controller ..> NavigationResult : returns
